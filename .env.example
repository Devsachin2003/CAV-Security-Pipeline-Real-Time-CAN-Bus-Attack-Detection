# Copy this file to .env and replace every password before starting Compose.
# Keep .env out of Git.

ELASTIC_PASSWORD=change-me-elastic-admin-password
KIBANA_SYSTEM_PASSWORD=change-me-kibana-system-password
ELASTIC_USER=elastic
ELASTICSEARCH_URL=http://localhost:9200
# Set ES_CA_CERT_PATH only when ELASTICSEARCH_URL uses HTTPS.
# ES_CA_CERT_PATH=.elastic_certs/http_ca.crt

ELASTICSEARCH_HOST_PORT=9200
KIBANA_HOST_PORT=5601

KAFKA_HOST_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BROKER_USER=broker
KAFKA_BROKER_PASSWORD=change-me-kafka-broker-password
KAFKA_USER=cav_app
KAFKA_PASSWORD=change-me-kafka-app-password
KAFKA_CA_CERT_PATH=.kafka_secrets/kafka.server.cer
KAFKA_SSL_KEYSTORE_PASSWORD=change-me-kafka-keystore-password
KAFKA_SSL_KEY_PASSWORD=change-me-kafka-keystore-password
KAFKA_SSL_TRUSTSTORE_PASSWORD=change-me-kafka-truststore-password
